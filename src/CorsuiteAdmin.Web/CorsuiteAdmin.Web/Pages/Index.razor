@page "/"
@using CorsuiteAdmin.Shared.DTOs
@using CorsuiteAdmin.Web.Services
@using CorsuiteAdmin.Web.Components
@inject ModuleService ModuleService
@inject ILogger<Index> Logger

<PageTitle>Corsuite Administration</PageTitle>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 mb-0">
                <i class="bi bi-gear-wide-connected me-2"></i>Corsuite Administration
            </h1>
            <p class="text-muted">Manage DLL modules in SAP Business One</p>
        </div>
        <div class="col-auto">
            <div class="d-flex align-items-center gap-2">
                @if (SapConnected)
                {
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i>Connected to @SapCompanyName
                    </span>
                    <button class="btn btn-outline-danger btn-sm" @onclick="DisconnectSap">
                        <i class="bi bi-unlink me-1"></i>Disconnect
                    </button>
                }
                <button class="btn btn-outline-primary btn-sm" @onclick="ShowSapConnectionDialog">
                    <i class="bi bi-link-45deg me-1"></i>SAP Connection
                </button>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control" placeholder="Search modules..." 
                       @bind="SearchQuery" @oninput="OnSearch">
            </div>
        </div>
        <div class="col-md-6 text-md-end">
            <div class="btn-group" role="group">
                <button class="btn btn-primary" @onclick="ShowAddDialog">
                    <i class="bi bi-plus-lg me-1"></i>Add Module
                </button>
                <button class="btn btn-outline-secondary" @onclick="RefreshModules" title="Refresh">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Module Source Tabs -->
    <ul class="nav nav-pills mb-4">
        <li class="nav-item">
            <button class="nav-link @(SelectedSource == "local" ? "active" : "")" @onclick="SelectLocalSource">
                <i class="bi bi-folder me-1"></i>Local Database
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(SelectedSource == "sap" ? "active" : "")" @onclick="SelectSapSource">
                <i class="bi bi-cloud me-1"></i>SAP B1 Modules
                @if (SapConnected)
                {
                    <span class="badge bg-success ms-1">@SapModules.Count</span>
                }
            </button>
        </li>
    </ul>

    <!-- Loading State -->
    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Loading modules...</p>
        </div>
    }
    else
    {
        <!-- Empty State -->
        @if (DisplayedModules.Count == 0)
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <h4 class="mt-3">No modules found</h4>
                <p class="text-muted">
                    @if (SelectedSource == "sap" && !SapConnected)
                    {
                        <text>Connect to SAP B1 to view Corsuite modules</text>
                    }
                    else
                    {
                        <text>Add a module or connect to SAP B1 to get started</text>
                    }
                </p>
                @if (SelectedSource == "sap" && !SapConnected)
                {
                    <button class="btn btn-primary" @onclick="ShowSapConnectionDialog">
                        <i class="bi bi-link-45deg me-1"></i>Connect to SAP B1
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="ShowAddDialog">
                        <i class="bi bi-plus-lg me-1"></i>Add First Module
                    </button>
                }
            </div>
        }
        else
        {
            <!-- Module Grid - Local Modules -->
            @if (SelectedSource == "local")
            {
                <div class="row g-4">
                    @foreach (var module in LocalModules.Where(m => string.IsNullOrEmpty(SearchQuery) || 
                        m.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)))
                    {
                        <div class="col-md-6 col-lg-4">
                            <ModuleCard Module="module" 
                                        OnEdit="() => ShowEditDialog(module)"
                                        OnDelete="() => ConfirmDelete(module)" />
                        </div>
                    }
                </div>
            }
            <!-- SAP Modules Grid -->
            else
            {
                <div class="row g-4">
                    @foreach (var module in SapModules.Where(m => string.IsNullOrEmpty(SearchQuery) || 
                        m.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)))
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 module-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-start mb-3">
                                        <div class="module-icon">
                                            <i class="bi bi-cloud"></i>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <h5 class="card-title mb-1">@module.Name</h5>
                                            <span class="badge bg-secondary">@module.Version</span>
                                        </div>
                                        <div class="status-indicator bg-success"></div>
                                    </div>
                                    <p class="card-text small text-muted mb-2">
                                        @(module.Description ?? "No description")
                                    </p>
                                    <div class="small text-muted">
                                        <i class="bi bi-hash me-1"></i>@module.AddOnId
                                        <span class="ms-2 badge bg-@(module.Status == "Active" ? "success" : "secondary")">
                                            @module.Status
                                        </span>
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent">
                                    <button class="btn btn-sm btn-outline-primary" 
                                            @onclick="() => ImportModule(module)">
                                        <i class="bi bi-download me-1"></i>Import to Local
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    }
</div>

<!-- Dialogs -->
<AddEditModuleDialog IsVisible="ShowAddEditDialog" 
                     IsEdit="IsEditMode"
                     Module="SelectedModule"
                     OnSave="SaveModule"
                     OnClose="CloseAddEditDialog" />

<ConfirmDialog IsVisible="ShowDeleteDialog"
               Title="Delete Module"
               Message="Are you sure you want to delete this module? This action cannot be undone."
               OnConfirm="DeleteModule"
               OnCancel="CancelDelete" />

<SapConnectionDialog IsVisible="ShowSapDialog"
                     ConnectToSapAsync="HandleSapConnect"
                     QueryCorsuiteModulesAsync="HandleQueryCorsuite"
                     ScanCorsuiteFilesAsync="HandleScanFiles"
                     OnConnect="OnSapConnected"
                     OnClose="CloseSapDialog" />

<ToastNotification @ref="Toast" />

@code {
    private List<DllModuleDto> LocalModules { get; set; } = new();
    private List<SapAddOnInfoDto> SapModules { get; set; } = new();
    private string SelectedSource { get; set; } = "local";
    private string SearchQuery { get; set; } = string.Empty;
    private bool IsLoading { get; set; }
    private bool ShowAddEditDialog { get; set; }
    private bool ShowDeleteDialog { get; set; }
    private bool ShowSapDialog { get; set; }
    private bool IsEditMode { get; set; }
    private bool SapConnected { get; set; }
    private string? SapCompanyName { get; set; }
    private DllModuleDto? SelectedModule { get; set; }
    private DllModuleDto? ModuleToDelete { get; set; }
    private ToastNotification? Toast;

    private List<object> DisplayedModules => SelectedSource == "local" 
        ? LocalModules.Cast<object>().ToList()
        : SapModules.Cast<object>().ToList();

    protected override async Task OnInitializedAsync()
    {
        await RefreshModules();
        await CheckSapConnectionStatus();
    }

    private async Task RefreshModules()
    {
        IsLoading = true;
        try
        {
            LocalModules = (await ModuleService.GetAllModulesAsync()).ToList();
            
            if (SapConnected)
            {
                SapModules = (await ModuleService.GetSapAddonsAsync()).ToList();
            }
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task CheckSapConnectionStatus()
    {
        var status = await ModuleService.GetSapConnectionStatusAsync();
        SapConnected = status?.IsConnected ?? false;
        SapCompanyName = status?.CompanyName;
        
        if (SapConnected)
        {
            SapModules = (await ModuleService.GetSapAddonsAsync()).ToList();
        }
    }

    private void SelectLocalSource() => SelectedSource = "local";
    private void SelectSapSource() => SelectedSource = "sap";

    private void OnSearch() { }

    private void ShowAddDialog()
    {
        SelectedModule = new DllModuleDto();
        IsEditMode = false;
        ShowAddEditDialog = true;
    }

    private void ShowEditDialog(DllModuleDto module)
    {
        SelectedModule = new DllModuleDto
        {
            Id = module.Id,
            Name = module.Name,
            Version = module.Version,
            Description = module.Description,
            Status = module.Status
        };
        IsEditMode = true;
        ShowAddEditDialog = true;
    }

    private async Task SaveModule()
    {
        if (SelectedModule == null) return;

        if (IsEditMode)
        {
            var updateRequest = new UpdateModuleRequestDto
            {
                Name = SelectedModule.Name,
                Version = SelectedModule.Version,
                Description = SelectedModule.Description,
                Status = SelectedModule.Status
            };
            await ModuleService.UpdateModuleAsync(SelectedModule.Id, updateRequest);
            Toast?.Show("Success", "Module updated successfully", ToastNotification.ToastType.Success);
        }
        else
        {
            var createRequest = new CreateModuleRequestDto
            {
                Name = SelectedModule.Name,
                Version = SelectedModule.Version,
                Description = SelectedModule.Description,
                AddedBy = "Admin"
            };
            await ModuleService.CreateModuleAsync(createRequest);
            Toast?.Show("Success", "Module created successfully", ToastNotification.ToastType.Success);
        }

        CloseAddEditDialog();
        await RefreshModules();
    }

    private void CloseAddEditDialog()
    {
        ShowAddEditDialog = false;
        SelectedModule = null;
    }

    private void ConfirmDelete(DllModuleDto module)
    {
        ModuleToDelete = module;
        ShowDeleteDialog = true;
    }

    private async Task DeleteModule()
    {
        if (ModuleToDelete != null)
        {
            await ModuleService.DeleteModuleAsync(ModuleToDelete.Id);
            Toast?.Show("Success", "Module deleted successfully", ToastNotification.ToastType.Success);
            await RefreshModules();
        }
        CancelDelete();
    }

    private void CancelDelete()
    {
        ShowDeleteDialog = false;
        ModuleToDelete = null;
    }

    private void ShowSapConnectionDialog() => ShowSapDialog = true;
    private void CloseSapDialog() => ShowSapDialog = false;

    private async Task DisconnectSap()
    {
        await ModuleService.DisconnectFromSapAsync();
        SapConnected = false;
        SapCompanyName = null;
        SapModules.Clear();
        Toast?.Show("Disconnected", "Disconnected from SAP B1", ToastNotification.ToastType.Info);
        SelectedSource = "local";
    }

    private async Task<bool> HandleSapConnect(SapConnectionDto connection)
    {
        return await ModuleService.ConnectToSapAsync(connection);
    }

    private async Task<IEnumerable<SapAddOnInfoDto>> HandleQueryCorsuite(string connStr, string dbName)
    {
        if (string.IsNullOrEmpty(dbName))
        {
            return await ModuleService.QueryAddonsFromDatabaseAsync(connStr);
        }
        return await ModuleService.QueryCorsuiteModulesAsync(connStr, dbName);
    }

    private async Task<IEnumerable<SapAddOnInfoDto>> HandleScanFiles()
    {
        return await ModuleService.ScanCorsuiteFilesAsync();
    }

    private async Task OnSapConnected(bool connected)
    {
        SapConnected = connected;
        await CheckSapConnectionStatus();
        
        if (SapConnected)
        {
            Toast?.Show("Connected", $"Connected to SAP B1: {SapCompanyName}", ToastNotification.ToastType.Success);
            SelectedSource = "sap";
        }
    }

    private async Task ImportModule(SapAddOnInfoDto sapModule)
    {
        var createRequest = new CreateModuleRequestDto
        {
            Name = sapModule.Name,
            Version = sapModule.Version,
            Description = sapModule.Description,
            AddedBy = "SAP Import"
        };
        await ModuleService.CreateModuleAsync(createRequest);
        Toast?.Show("Imported", $"'{sapModule.Name}' imported to local database", ToastNotification.ToastType.Success);
        await RefreshModules();
        SelectedSource = "local";
    }
}
